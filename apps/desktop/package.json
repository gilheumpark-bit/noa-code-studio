{
  "name": "noa-code-studio",
  "version": "0.2.0-beta",
  "description": "NOA Code Studio — AI-Powered Desktop IDE with Verification Pipeline",
  "author": "gilheumpark-bit",
  "license": "CC-BY-NC-4.0",
  "private": true,
  "main": "app/main.js",
  "scripts": {
    "dev": "next dev renderer",
    "build": "next build renderer",
    "start": "node ./scripts/next-start.mjs renderer",
    "lint": "eslint renderer main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify:static": "npm run lint && node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --strict",
    "verify:build": "npm run verify:static && npm run build",
    "cs": "ts-node --project tsconfig.cli.json renderer/cli/bin/cs.ts",
    "cs:build": "tsc --project tsconfig.cli.json",
    "dev:electron": "nextron",
    "build:electron": "cross-env NODE_ENV=production nextron build --config electron-builder.yml --win --x64",
    "build:electron:all": "cross-env NODE_ENV=production nextron build --config electron-builder.yml",
    "electron:rebuild": "electron-builder install-app-deps"
  },
  "bin": {
    "cs": "./dist/cli/cli/bin/cs.js"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.29.2",
    "chokidar": "^3.6.0",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.3.9",
    "jszip": "^3.10.1",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0-beta22"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.52",
    "@noa/quill-cli": "workspace:*",
    "@noa/quill-engine": "workspace:*",
    "@noa/shared-types": "workspace:*",
    "@google/genai": "^1.49.0",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.159",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "isomorphic-git": "^1.37.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "nextron": "^10.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.7",
    "ts-morph": "^23.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "zustand": "^5.0.12"
  },
  "build": {
    "asar": true,
    "npmRebuild": false,
    "forceCodeSigning": false
  }
}
